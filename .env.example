# Database
DATABASE_URL=postgres://app:password@db:5432/member_origin_role

# Session signing secret (random string)
SESSION_SECRET=your_random_session_secret_here

# Public URL (HTTPS required by RoleLogic)
BASE_URL=https://your-plugin.example.com/member-origin-role

# Server bind address (optional, defaults to 0.0.0.0:8080)
LISTEN_ADDR=0.0.0.0:8080

# Auth Gateway integration (required — sync workers call /auth/internal/*)
# Defaults to deriving the origin from BASE_URL if unset. Set explicitly in local dev.
# AUTH_GATEWAY_URL=http://localhost:8090
# Shared secret — must match the Auth Gateway's INTERNAL_API_KEY value
INTERNAL_API_KEY=your_internal_api_key_here

# Log level (optional)
RUST_LOG=member_origin_role=info
